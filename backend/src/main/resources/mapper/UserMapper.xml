<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.retrack.mapper.UserMapper">

    <!--
        users 테이블 컬럼 → UserVO 필드 매핑
        password 컬럼은 resultMap에 포함되어 있으나,
        findAll / findById SELECT 절에서 의도적으로 제외하여 응답에 해시값이 노출되지 않도록 함
    -->
    <resultMap id="userResultMap" type="com.retrack.vo.UserVO">
        <id property="userId" column="user_id"/>
        <result property="username" column="username"/>
        <result property="password" column="password"/>
        <result property="email" column="email"/>
        <result property="phone" column="phone"/>
        <result property="role" column="role"/>
        <result property="isVerified" column="is_verified"/>
        <result property="verifiedAt" column="verified_at"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>

    <!-- 전체 사용자 목록 조회 (최신 가입순, password 제외) -->
    <select id="findAll" resultMap="userResultMap">
        SELECT user_id, username, email, phone, role, is_verified, verified_at, created_at, updated_at
        FROM users
        ORDER BY created_at DESC
    </select>

    <!-- 사용자 ID로 단건 조회 (password 제외) -->
    <select id="findById" parameterType="Long" resultMap="userResultMap">
        SELECT user_id, username, email, phone, role, is_verified, verified_at, created_at, updated_at
        FROM users
        WHERE user_id = #{userId}
    </select>

    <!-- 권한 변경 + updated_at 갱신 -->
    <update id="updateRole">
        UPDATE users
        SET role = #{role}, updated_at = NOW()
        WHERE user_id = #{userId}
    </update>

    <!-- 연구자 인증 승인: is_verified = TRUE, verified_at 기록 -->
    <update id="updateVerify" parameterType="Long">
        UPDATE users
        SET is_verified = TRUE, verified_at = NOW(), updated_at = NOW()
        WHERE user_id = #{userId}
    </update>

    <!-- 사용자 삭제 -->
    <delete id="deleteUser" parameterType="Long">
        DELETE FROM users
        WHERE user_id = #{userId}
    </delete>

</mapper>
