<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<!-- 최초 생성일: 2026-04-28 -->
<!-- @modified 2026-05-12 findAll dynamic SQL 검색 조건 추가 -->
<!-- @modified 2026-05-12 페이지네이션 LIMIT/OFFSET + countAll 추가 -->
<mapper namespace="com.retrack.mapper.UserMapper">

    <!--
        users 테이블 컬럼 → UserVO 필드 매핑
        password 컬럼은 resultMap에 포함되어 있으나,
        findAll / findById SELECT 절에서 의도적으로 제외하여 응답에 해시값이 노출되지 않도록 함
    -->
    <resultMap id="userResultMap" type="com.retrack.vo.UserVO">
        <id property="userId" column="user_id"/>
        <result property="username" column="username"/>
        <result property="password" column="password"/>
        <result property="email" column="email"/>
        <result property="phone" column="phone"/>
        <result property="role" column="role"/>
        <result property="isVerified" column="is_verified"/>
        <result property="verifiedAt" column="verified_at"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>

    <!-- 사용자 검색 공통 WHERE 조건 (findAll, countAll에서 공유) -->
    <sql id="userSearchConditions">
        <where>
            <if test="keyword != null and keyword != ''">
                <!-- ILIKE '%keyword%'는 앞 와일드카드로 B-tree 인덱스 불가 → full table scan 발생
                     개선안: pg_bigm 확장 + GIN 인덱스로 한국어 부분 일치 검색 최적화 가능 -->
                (username ILIKE '%' || #{keyword} || '%' OR email ILIKE '%' || #{keyword} || '%')
            </if>
            <if test="role != null and role != ''">
                AND role = #{role}
            </if>
            <if test="isVerified != null">
                AND is_verified = #{isVerified}
            </if>
        </where>
    </sql>

    <!--
        사용자 목록 조회 (검색 조건 선택 적용, 최신 가입순, password 제외)
        파라미터: keyword, role, isVerified, size, offset
    -->
    <select id="findAll" parameterType="map" resultMap="userResultMap">
        SELECT user_id, username, email, phone, role, is_verified, verified_at, created_at, updated_at
        FROM users
        <include refid="userSearchConditions"/>
        ORDER BY created_at DESC
        LIMIT #{size} OFFSET #{offset}
    </select>

    <!-- 검색 조건에 맞는 사용자 총 건수 (페이지네이션용) -->
    <select id="countAll" parameterType="map" resultType="long">
        SELECT COUNT(*)
        FROM users
        <include refid="userSearchConditions"/>
    </select>

    <!-- 사용자 ID로 단건 조회 (password 제외) -->
    <select id="findById" parameterType="Long" resultMap="userResultMap">
        SELECT user_id, username, email, phone, role, is_verified, verified_at, created_at, updated_at
        FROM users
        WHERE user_id = #{userId}
    </select>

    <!-- 권한 변경 + updated_at 갱신 -->
    <update id="updateRole">
        UPDATE users
        SET role = #{role}, updated_at = NOW()
        WHERE user_id = #{userId}
    </update>

    <!-- 연구자 인증 승인: is_verified = TRUE, verified_at 기록 -->
    <update id="updateVerify" parameterType="Long">
        UPDATE users
        SET is_verified = TRUE, verified_at = NOW(), updated_at = NOW()
        WHERE user_id = #{userId}
    </update>

    <!-- 사용자 삭제 -->
    <delete id="deleteUser" parameterType="Long">
        DELETE FROM users
        WHERE user_id = #{userId}
    </delete>

</mapper>
