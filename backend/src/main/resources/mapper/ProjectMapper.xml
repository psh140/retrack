<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.retrack.mapper.ProjectMapper">

    <!-- projects 테이블 컬럼 → ProjectVO 필드 매핑 -->
    <resultMap id="projectResultMap" type="com.retrack.vo.ProjectVO">
        <id property="projectId" column="project_id"/>
        <result property="title" column="title"/>
        <result property="description" column="description"/>
        <result property="status" column="status"/>
        <result property="userId" column="user_id"/>
        <result property="managerId" column="manager_id"/>
        <result property="startDate" column="start_date"/>
        <result property="endDate" column="end_date"/>
        <result property="budgetTotal" column="budget_total"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>

    <!-- project_history 테이블 컬럼 → ProjectHistoryVO 필드 매핑 -->
    <resultMap id="historyResultMap" type="com.retrack.vo.ProjectHistoryVO">
        <id property="historyId" column="history_id"/>
        <result property="projectId" column="project_id"/>
        <result property="changedBy" column="changed_by"/>
        <result property="prevStatus" column="prev_status"/>
        <result property="newStatus" column="new_status"/>
        <result property="comment" column="comment"/>
        <result property="changedAt" column="changed_at"/>
    </resultMap>

    <!-- 전체 과제 목록 조회 (최신 등록순) -->
    <select id="findAll" resultMap="projectResultMap">
        SELECT project_id, title, description, status, user_id, manager_id,
               start_date, end_date, budget_total, created_at, updated_at
        FROM projects
        ORDER BY created_at DESC
    </select>

    <!-- 과제 ID로 단건 조회 -->
    <select id="findById" parameterType="Long" resultMap="projectResultMap">
        SELECT project_id, title, description, status, user_id, manager_id,
               start_date, end_date, budget_total, created_at, updated_at
        FROM projects
        WHERE project_id = #{projectId}
    </select>

    <!--
        과제 등록
        useGeneratedKeys=true: INSERT 후 생성된 PK를 projectId 필드에 자동 주입
    -->
    <insert id="insertProject" parameterType="com.retrack.vo.ProjectVO"
            useGeneratedKeys="true" keyProperty="projectId">
        INSERT INTO projects (title, description, user_id, manager_id, start_date, end_date, budget_total)
        VALUES (#{title}, #{description}, #{userId}, #{managerId}, #{startDate}, #{endDate}, #{budgetTotal})
    </insert>

    <!--
        과제 수정
        null인 필드는 <if> 조건으로 제외하여 의도치 않은 덮어쓰기 방지
    -->
    <update id="updateProject" parameterType="com.retrack.vo.ProjectVO">
        UPDATE projects
        <set>
            title = #{title},
            description = #{description},
            <if test="managerId != null">manager_id = #{managerId},</if>
            <if test="startDate != null">start_date = #{startDate},</if>
            <if test="endDate != null">end_date = #{endDate},</if>
            <if test="budgetTotal != null">budget_total = #{budgetTotal},</if>
            updated_at = NOW()
        </set>
        WHERE project_id = #{projectId}
    </update>

    <!-- 과제 상태 업데이트 (changeStatus 트랜잭션 1번) -->
    <update id="updateStatus">
        UPDATE projects
        SET status = #{status}, updated_at = NOW()
        WHERE project_id = #{projectId}
    </update>

    <!-- 과제 삭제 -->
    <delete id="deleteProject" parameterType="Long">
        DELETE FROM projects
        WHERE project_id = #{projectId}
    </delete>

    <!-- 상태 변경 이력 INSERT (changeStatus 트랜잭션 2번) -->
    <insert id="insertHistory" parameterType="com.retrack.vo.ProjectHistoryVO">
        INSERT INTO project_history (project_id, changed_by, prev_status, new_status, comment)
        VALUES (#{projectId}, #{changedBy}, #{prevStatus}, #{newStatus}, #{comment})
    </insert>

    <!-- 알림 기록 INSERT — 카카오 발송 전 DB 선기록 (changeStatus 트랜잭션 3번) -->
    <insert id="insertNotification">
        INSERT INTO k_notifications (user_id, project_id, message)
        VALUES (#{userId}, #{projectId}, #{message})
    </insert>

    <!-- 특정 과제의 상태 변경 이력 목록 조회 (최신순) -->
    <select id="findHistoryByProjectId" parameterType="Long" resultMap="historyResultMap">
        SELECT history_id, project_id, changed_by, prev_status, new_status, comment, changed_at
        FROM project_history
        WHERE project_id = #{projectId}
        ORDER BY changed_at DESC
    </select>

</mapper>
