# 기본: 텍스트 파일은 LF로 정규화
* text=auto eol=lf

# Windows 배치/PowerShell은 CRLF 유지
*.cmd text eol=crlf
*.bat text eol=crlf
*.ps1 text eol=crlf

# Maven wrapper
mvnw text eol=lf
mvnw.cmd text eol=crlf

# 바이너리 — 줄바꿈 변환 제외
*.war binary
*.jar binary
*.class binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
